# ============================================================
# KUMPAX STORE — Configuration Environnement
# ============================================================
# Copier ce fichier en .env et remplir vos valeurs

# ── Odoo ──────────────────────────────────────────────────
ODOO_URL=https://votre-instance.odoo.com
ODOO_DB=votre-db
ODOO_USER=admin
ODOO_PASS=password

# ── Serveur API ────────────────────────────────────────────
PORT=3001
# Liste d'URLs séparées par des virgules (sans slash à la fin)
FRONTEND_URL=http://localhost:3000,http://localhost:3001
NODE_ENV=development
ADMIN_TOKEN=votre-token-secret-ici

# ── Admin Dashboard ────────────────────────────────────────
ADMIN_USER=admin
# Mot de passe hashé bcrypt (recommandé)
ADMIN_PASS_HASH=$2b$12$replace-me-with-bcrypt-hash
# Fallback local uniquement (si ADMIN_PASS_HASH absent/invalide)
# ADMIN_PASS=votre-mot-de-passe-admin
JWT_SECRET=changez-ce-secret-en-production

# ── Optionnel : cache Redis ───────────────────────────────
REDIS_URL=redis://localhost:6379
# CACHE_TTL_PRODUCTS=300
